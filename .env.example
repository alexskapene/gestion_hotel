# ===========================================
# Variables requises en local ET sur Vercel
# (Project Settings → Environment Variables)
# ===========================================

# Base de données MySQL (sans chemin vers certs/ en production)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Si votre hébergeur MySQL exige un certificat CA (fichier dans certs/ en local) :
# 1. Ouvrez le fichier .pem (ex. certs/ca.pem)
# 2. Copiez tout le contenu (-----BEGIN CERTIFICATE----- ...)
# 3. Sur Vercel, créez DATABASE_SSL_CA et collez ce contenu (une seule variable)
# Ne mettez PAS de chemin type ./certs/ca.pem dans DATABASE_URL sur Vercel.
# DATABASE_SSL_CA="-----BEGIN CERTIFICATE-----
# ...
# -----END CERTIFICATE-----"

# NextAuth v5 — OBLIGATOIRE en production (sinon erreur "Server configuration")
# Générer : openssl rand -base64 32
AUTH_SECRET="votre-secret-aleatoire-32-caracteres-minimum"

# URL publique de l'app (sur Vercel : https://votre-projet.vercel.app)
AUTH_URL="http://localhost:3000"

# Alias accepté si vous aviez l'ancienne doc
# NEXTAUTH_SECRET="meme-valeur-que-AUTH_SECRET"
# NEXTAUTH_URL="http://localhost:3000"

# Optionnel
NEXT_PUBLIC_APP_URL="http://localhost:3000"
